# Make sure RUBY_VERSION matches the Ruby version in .ruby-version and Gemfile
ARG RUBY_VERSION=4.0.0-bookworm
FROM ruby:$RUBY_VERSION

WORKDIR /app

# Set development environment
ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT="production" \
    PATH="/usr/local/node/bin:$PATH" \
    npm_config_cache="/app/.npm" \
    IS_APP_SERVER=true

# Install packages needed for both building and running the application
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y build-essential curl git libpq-dev libvips node-gyp pkg-config python3 python-is-python3 postgresql-client libproj-dev libgeos-dev proj-bin netcat-openbsd xvfb libatk1.0-0 libatk-bridge2.0-0 libcups2 libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2 libpangocairo-1.0-0 libpango-1.0-0 libgdk-pixbuf2.0-0 libgtk-3-0 libnss3 libxss1 libx11-xcb1 libxtst6 wget gnupg2 chromium && \
    rm -rf /var/lib/apt/lists/*

# Create virus scan temp directory for ClamAV service communication
RUN mkdir -p /tmp/virus_scan && \
    chmod 755 /tmp/virus_scan

# Install Node.js first (smaller layer, changes less frequently)
ARG NODE_VERSION=24.15.0
RUN curl -sL https://github.com/nodenv/node-build/archive/master.tar.gz | tar xz -C /tmp/ && \
    cd /tmp/node-build-master && ./install.sh && \
    /tmp/node-build-master/bin/node-build "${NODE_VERSION}" /usr/local/node && \
    rm -rf /tmp/node-build-master

# Install Ruby gems (separate layer for better caching)
COPY Gemfile Gemfile.lock ./
RUN BUNDLER_VERSION="$(ruby -e 'lock = File.read("Gemfile.lock"); puts lock[/^BUNDLED WITH\n\s+([0-9.]+)/m, 1]')" && \
    gem install "bundler:${BUNDLER_VERSION}" && \
    bundle _${BUNDLER_VERSION}_ install

# Install Node dependencies (before copying app code for better caching)
COPY package.json package-lock.json ./
RUN npm install --maxsockets=50 --ignore-scripts

# Copy application code (this layer changes most frequently)
COPY . .

# Run postinstall scripts now that app code is present
RUN npm run gen:theme-typings

RUN bundle config set --local path "$BUNDLE_PATH" && \
    bundle config set --local without "$BUNDLE_WITHOUT" && \
    bundle install

RUN bundle exec bootsnap precompile app/ lib/

EXPOSE 3000
ENTRYPOINT ["./devops/docker/app/entrypoint-dev.sh"]
# CMD ["./bin/rails", "server"]

