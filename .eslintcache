ook useEffect has missing dependencies: 'getDefaultRevisionRequestValues' and 'reset'. Either include them or remove the dependency array.",["24516"],"React Hook useEffect has a missing dependency: 'handleOpenRequestRevision'. Either include it or remove the dependency array.",["24517"],["24518"],"React Hook useEffect has missing dependencies: 'permitApplication?.id', 'permitApplicationStore', and 'review'. Either include them or remove the dependency array.",["24519"],"'error' is defined but never used.","React Hook useEffect has a missing dependency: 'permitApplication'. Either include it or remove the dependency array.",["24520"],["24521"],["24522"],"'result' is assigned a value but never used.",["24523","24524"],"'IProps' is defined but never used.","React Hook useEffect has missing dependencies: 'externalApiKeyId' and 'reset'. Either include them or remove the dependency array.",["24525"],{"range":"24526","text":"24285"},{"range":"24527","text":"24285"},{"range":"24528","text":"24285"},{"range":"24529","text":"24285"},{"range":"24530","text":"24285"},{"range":"24531","text":"24285"},{"range":"24532","text":"24285"},{"range":"24533","text":"24285"},{"range":"24534","text":"24285"},{"range":"24535","text":"24285"},{"range":"24536","text":"24285"},{"range":"24537","text":"24285"},{"range":"24538","text":"24285"},{"range":"24539","text":"24285"},{"range":"24540","text":"24285"},{"range":"24541","text":"24285"},{"range":"24542","text":"24285"},{"range":"24543","text":"24285"},{"range":"24544","text":"24285"},{"range":"24545","text":"24285"},{"range":"24546","text":"24285"},{"range":"24547","text":"24285"},["24548"],"'useJurisdiction' is defined but never used.",["24549"],"An interface declaring no members is equivalent to its supertype.","noEmptyInterfaceWithSuper",["24550"],"'BookOpen' is defined but never used.",["24551"],"'Buildings' is defined but never used.",["24552"],"'Clock' is defined but never used.",["24553"],"'FileText' is defined but never used.",["24554"],"'Folder' is defined but never used.",["24555"],"'rest' is defined but never used.","'useLocation' is defined but never used.",["24556"],["24557","24558"],"'permitApplicationStore' is assigned a value but never used.","React Hook useEffect has a missing dependency: 'contractorStore'. Either include it or remove the dependency array.",["24559"],"React Hook useCallback has missing dependencies: 'importHandled', 'importToken', and 'setImportToken'. Either include them or remove the dependency array.",["24560"],"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/domains/home/contractor-onboarding.tsx:145:5\n  143 |   useEffect(() => {\n  144 |     cancelledRef.current = false;\n> 145 |     checkOnboarding();\n      |     ^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  146 |     return () => {\n  147 |       cancelledRef.current = true;\n  148 |     };","React Hook useEffect has an unnecessary dependency: 'location.pathname'. Either exclude it or remove the dependency array. Outer scope values like 'location.pathname' aren't valid dependencies because mutating them doesn't re-render the component.",["24561"],"'CaretRight' is defined but never used.",["24562"],"'isSandboxActive' is assigned a value but never used.",["24563","24564"],["24565"],"'unreadNotificationsCount' is assigned a value but never used.",{"range":"24566","text":"24285"},{"range":"24567","text":"24285"},{"range":"24568","text":"24285"},{"range":"24569","text":"24285"},{"range":"24570","text":"24285"},{"range":"24571","text":"24285"},{"range":"24572","text":"24285"},{"range":"24573","text":"24285"},{"range":"24574","text":"24285"},{"range":"24575","text":"24285"},"react/no-children-prop","Do not pass children as props. Instead, nest children between the opening and closing tags.","JSXAttribute","nestChildren","'i' is defined but never used.",{"range":"24576","text":"24285"},{"range":"24577","text":"24285"},{"range":"24578","text":"24285"},{"range":"24579","text":"24285"},{"range":"24580","text":"24285"},{"range":"24581","text":"24285"},{"range":"24582","text":"24285"},{"range":"24583","text":"24285"},{"range":"24584","text":"24285"},{"range":"24585","text":"24285"},{"range":"24586","text":"24285"},{"range":"24587","text":"24285"},{"range":"24588","text":"24285"},{"range":"24589","text":"24285"},{"range":"24590","text":"24285"},{"range":"24591","text":"24285"},{"range":"24592","text":"24285"},{"range":"24593","text":"24285"},{"range":"24594","text":"24285"},{"range":"24595","text":"24285"},{"range":"24596","text":"24285"},{"range":"24597","text":"24285"},{"range":"24598","text":"24285"},{"range":"24599","text":"24285"},{"range":"24600","text":"24285"},{"range":"24601","text":"24285"},{"range":"24602","text":"24285"},"'insert' is assigned a value but never used.",{"range":"24603","text":"24285"},{"range":"24604","text":"24285"},{"range":"24605","text":"24285"},{"range":"24606","text":"24285"},{"range":"24607","text":"24285"},{"range":"24608","text":"24285"},{"range":"24609","text":"24285"},{"range":"24610","text":"24285"},{"range":"24611","text":"24285"},{"range":"24612","text":"24285"},{"range":"24613","text":"24285"},{"range":"24614","text":"24285"},{"range":"24615","text":"24285"},{"range":"24616","