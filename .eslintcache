"},"'fetchingPids' is assigned a value but never used.",{"range":"31814","text":"24285"},{"range":"31815","text":"24285"},{"range":"31816","text":"24285"},{"range":"31817","text":"24285"},{"range":"31818","text":"24285"},{"range":"31819","text":"24285"},{"range":"31820","text":"24285"},{"range":"31821","text":"24285"},{"range":"31822","text":"24285"},{"range":"31823","text":"24285"},{"range":"31824","text":"24285"},{"range":"31825","text":"24285"},{"range":"31826","text":"24285"},{"range":"31827","text":"24285"},{"range":"31828","text":"24285"},{"range":"31829","text":"24285"},{"range":"31830","text":"24285"},{"range":"31831","text":"24285"},{"range":"31832","text":"28637"},{"range":"31833","text":"24285"},{"range":"31834","text":"24285"},{"range":"31835","text":"24285"},"React Hook useEffect has missing dependencies: 'fetchSiteDetailsFromPid', 'setValue', and 'siteName'. Either include them or remove the dependency array.",["31836"],{"range":"31837","text":"24285"},{"range":"31838","text":"24285"},["31839"],{"range":"31840","text":"24285"},{"range":"31841","text":"24285"},{"range":"31842","text":"24285"},{"range":"31843","text":"24285"},{"range":"31844","text":"24285"},{"range":"31845","text":"24285"},{"range":"31846","text":"24285"},{"range":"31847","text":"24285"},{"range":"31848","text":"24285"},{"range":"31849","text":"24285"},{"range":"31850","text":"24285"},{"range":"31851","text":"24285"},{"range":"31852","text":"24285"},{"range":"31853","text":"24285"},{"range":"31854","text":"24285"},{"range":"31855","text":"24285"},{"range":"31856","text":"24285"},{"range":"31857","text":"24285"},{"range":"31858","text":"24285"},{"range":"31859","text":"24285"},{"range":"31860","text":"24285"},{"range":"31861","text":"24285"},{"range":"31862","text":"24285"},{"range":"31863","text":"24285"},["31864"],{"range":"31865","text":"24285"},{"range":"31866","text":"24285"},{"range":"31867","text":"24285"},"Error: Expected the dependency list for useMemo to be an array literal\n\nExpected the dependency list for useMemo to be an array literal.\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/select/selectors/sort-select.tsx:36:6\n  34 |     })\n  35 |     return sortOptions\n> 36 |   }, sortFields)\n     |      ^^^^^^^^^^ Expected the dependency list for useMemo to be an array literal\n  37 |\n  38 |   const { applySort, fetchData, sort } = searchModel\n  39 |","React Hook useMemo was passed a dependency list that is not an array literal. This means we can't statically verify whether you've passed the correct dependencies.","React Hook useMemo has missing dependencies: 'i18nPrefix', 'sortFields', and 't'. Either include them or remove the dependency array.",["31868"],{"range":"31869","text":"24285"},{"range":"31870","text":"24285"},{"range":"31871","text":"24285"},{"range":"31872","text":"24285"},"Error: Cannot access variable before it is declared\n\n`setSelectedOption` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/select/selectors/sort-select.tsx:45:5\n  43 |     const selected = sortOptions.find((so) => so.value.field === sort.field && so.value.direction === sort.direction)\n  44 |\n> 45 |     setSelectedOption(selected)\n     |     ^^^^^^^^^^^^^^^^^ `setSelectedOption` accessed before it is declared\n  46 |   }, [JSON.stringify(sort)])\n  47 |\n  48 |   const [selectedOption, setSelectedOption] = useState<IOption<ISort>>(null)\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/select/selectors/sort-select.tsx:48:26\n  46 |   }, [JSON.stringify(sort)])\n  47 |\n> 48 |   const [selectedOption, setSelectedOption] = useState<IOption<ISort>>(null)\n     |                          ^^^^^^^^^^^^^^^^^ `setSelectedOption` is declared here\n  49 |\n  50 |   const handleChange = (selectedOption: IOption<ISort> | null) => {\n  51 |     if (selectedOption) {",{"range":"31873","text":"24285"},"React Hook useEffect has missing dependencies: 'sort' and 'sortOptions'. Either include them or remove the dependency array.",["31874"],"React Hook useEffect has a complex expression in the dependency array. Extract it to a separate variable so it can be statically checked.",{"range":"31875","text":"24285"},{"range":"31876","text":"24285"},{"range":"31877","text":"24285"},{"range":"31878","text":"24285"},{"range":"31879","text":"24285"},{"range":"31880","text":"24285"},{"range":"31881","text":"24285"},{"range":"31882","text":"24285"},{"range":"31883","text":"24285"},{"range":"31884","text":"24285"},{"range":"31885","text":"24285"},{"range":"31886","text":"24285"},{"range":"31887","text":"24285"},{"range":"31888","text":"24285"},{"range":"31889","text":"24285"},{"range":"31890","text":"24285"},{"range":"31891","text":"24285"},"React Hook useEffect has missing dependencies: 'sortedOptions' and 'value'. Either include them or remove the dependency array.",["31892"],{"range":"31893","text":"24285"},{"range":"31894","text":"24285"},{"range":"31895","text":"24285"},{"range":"31896","text":"24285"},{"range":"31897","text":"24285"},{"range":"31898","text":"24285"},{"range":"31899","text":"24285"},{"range":"31900","text":"24285"},{"range":"31901","text":"24285"},{"range":"31902","text":"24285"},{"range":"31903","text":"24285"},{"range":"31904","text":"24285"},{"range":"31905","text":"24285"},{"range":"31906","text":"24285"},{"range":"31907","text":"24285"},{"range":"31908","text":"24285"},{"range":"31909","text":"24285"},{"range":"31910","text":"24285"},{"range":"31911","text":"24285"},{"range":"31912","text":"24285"},{"range":"31913","text":"24285"},["31914"],{"range":"31915","text":"24285"},{"range":"31916","text":"24285"},{"range":"31917","text":"24285"},{"range":"31918","text":"24285"},{"range":"31919","text":"24285"},{"range":"31920","text":"24285"},{"range":"31921","text":"24285"},{"range":"31922","text":"24285"},{"range":"31923","text":"24285"},{"range":"31924","text":"24285"},{"range":"31925","text":"24285"},{"range":"31926","text":"24285"},{"range":"31927","text":"24285"},{"range":"31928","text":"24285"},{"range":"31929","text":"24285"},{"range":"31930","text":"24285"},{"range":"31931","text":"24285"},{"range":"31932","text":"24285"},{"range":"31933","text":"24285"},{"range":"31934","text":"24285"},{"range":"31935","text":"24285"},{"range":"31936","text":"24285"},{"range":"31937","text":"24285"},{"range":"31938","text":"24285"},{"range":"31939","text":"24285"},{"range":"31940","text":"24285"},{"range":"31941","text":"24285"},{"range":"31942","text":"24285"},{"range":"31943","text":"24285"},"React Hook \"useMst\" is called in function \"can\" that is neither a React function component nor a custom React Hook function. React component names must start with an uppercase letter. React Hook names must start with the word \"use\".",{"range":"31944","text":"24285"},{"range":"31945","text":"24285"},{"range":"31946","text":"24285"},{"range":"31947","text":"24285"},{"range":"31948","text":"24285"},{"range":"31949","text":"24285"},{"range":"31950","text":"24285"},{"range":"31951","text":"24285"},{"range":"31952","text":"24285"},{"range":"31953","text":"24285"},{"range":"31954","text":"24285"},{"range":"31955","text":"24285"},{"range":"31956","text":"24285"},{"range":"31957","text":"24285"},{"range":"31958","text":"24285"},"'FormErrorMessage' is defined but never used.",["31959"],"'WarningCircle' is defined but never used.",["31960"],"'takenActive' is assigned a value but never used.","'takenDeactivated' is assigned a value but never used.",["31961"],"'environment' is assigned a value but never used.",["31962"],"'confirmText' is assigned a value but never used.","'isSaving' is assigned a value but never used.",["31963"],"'ClockClockwise' is defined but never used.",["31964"],"'PaperPlaneTilt' is defined but never used.",["31965"],"'Console' is defined but never used.",["31966"],{"range":"31967","text":"24285"},{"range":"31968","text":"24285"},{"range":"31969","text":"24285"},{"range":"31970","text":"24285"},{"range":"31971","text":"24285"},{"range":"31972","text":"24285"},{"range":"31973","text":"24285"},{"range":"31974","text":"24285"},{"range":"31975","text":"24285"},{"range":"31976","text":"24285"},{"range":"31977","text":"24285"},{"range":"31978","text":"24285"},{"range":"31979","text":"24285"},{"range":"31980","text":"24285"},{"range":"31981","text":"24285"},{"range":"31982","text":"24285"},{"range":"31983","text":"24285"},{"range":"31984","text":"24285"},{"range":"31985","text":"24285"},{"range":"31986","text":"24285"},{"range":"31987","text":"24285"},{"range":"31988","text":"24285"},{"range":"31989","text":"24285"},{"range":"31990","text":"24285"},{"range":"31991","text":"24285"},{"range":"31992","text":"24285"},{"range":"31993","text":"24285"},{"range":"31994","text":"24285"},{"range":"31995","text":"24285"},"React Hook useMemo has a missing dependency: 't'. Either include it or remove the dependency array.",["31996"],{"range":"31997","text":"24285"},{"range":"31998","text":"24285"},"React Hook useMemo has unnecessary dependencies: 'error' and 'isLoading'. Either exclude them or remove the dependency array.",["31999"],{"range":"32000","text":"24285"},{"range":"32001","text":"24285"},{"range":"32002","text":"24285"},{"range":"32003","text":"24285"},{"range":"32004","text":"24285"},{"range":"32005","text":"24285"},{"range":"32006","text":"24285"},{"range":"32007","text":"24285"},{"range":"32008","text":"24285"},{"range":"32009","text":"24285"},{"range":"32010","text":"24285"},{"range":"32011","text":"24285"},{"range":"32012","text":"24285"},{"range":"32013","text":"24285"},{"range":"32014","text":"24285"},{"range":"32015","text":"24285"},{"range":"32016","text":"24285"},{"range":"32017","text":"24285"},{"range":"32018","text":"24285"},{"range":"32019","text":"24285"},{"range":"32020","text":"24285"},{"range":"32021","text":"24285"},{"range":"32022","text":"24285"},{"range":"32023","text":"24285"},{"range":"32024","text":"24285"},{"range":"32025","text":"24285"},{"range":"32026","text":"24285"},{"range":"32027","text":"24285"},{"range":"32028","text":"24285"},{"range":"32029","text":"24285"},{"range":"32030","text":"24285"},["32031"],{"range":"32032","text":"24285"},{"range":"32033","text":"24285"},{"range":"32034","text":"24285"},{"range":"32035","text":"24285"},{"range":"32036","text":"24285"},{"range":"32037","text":"24285"},{"range":"32038","text":"24285"},{"range":"32039","text":"24285"},{"range":"32040","text":"24285"},{"range":"32041","text":"24285"},{"range":"32042","text":"24285"},"no-useless-escape","Unnecessary escape character: \\[.","Literal","unnecessaryEscape",["32043","32044"],["32045","32046"],["32047"],["32048"],["32049"],{"range":"32050","text":"24285"},{"range":"32051","text":"24285"},["32052"],{"range":"32053","text":"24285"},{"range":"32054","text":"24285"},{"range":"32055","text":"24285"},{"range":"32056","text":"24285"},{"range":"32057","text":"24285"},{"range":"32058","text":"24285"},{"range":"32059","text":"24285"},{"range":"32060","text":"24285"},{"range":"32061","text":"24285"},{"range":"32062","text":"24285"},{"range":"32063","text":"26508"},{"range":"32064","text":"24285"},{"range":"32065","text":"24285"},"ThrowStatement",{"range":"32066","text":"24285"},{"range":"32067","text":"24285"},{"range":"32068","text":"24285"},{"range":"32069","text":"24285"},"React Hook useEffect has missing dependencies: 'activityOptions', 'customErrorMessage', 'error', 'fetchActivityOptions', and 't'. Either include them or remove the dependency array.",["32070"],{"range":"32071","text":"24285"},{"range":"32072","text":"24285"},{"range":"32073","text":"24285"},{"range":"32074","text":"24285"},{"range":"32075","text":"24285"},{"range":"32076","text":"24285"},{"range":"32077","text":"24285"},{"range":"32078","text":"24285"},{"range":"32079","text":"24285"},{"range":"32080","text":"24285"},{"range":"32081","text":"26508"},{"range":"32082","text":"24285"},{"range":"32083","text":"24285"},{"range":"32084","text":"24285"},{"range":"32085","text":"24285"},{"range":"32086","text":"24285"},"React Hook useEffect has missing dependencies: 'customErrorMessage', 'error', 'fetchAutoComplianceModuleConfigurations', and 't'. Either include them or remove the dependency array.",["32087"],{"range":"32088","text":"24285"},{"range":"32089","text":"24285"},"React Hook useEffect has missing dependencies: 'fetchContractor', 'getContractor', 'setCurrentContractor', and 't'. Either include them or remove the dependency array.",["32090"],"React Hook useEffect has missing dependencies: 'currentContractor?.id' and 'setCurrentContractor'. Either include them or remove the dependency array.",["32091"],{"range":"32092","text":"24285"},{"range":"32093","text":"24285"},{"range":"32094","text":"24285"},{"range":"32095","text":"24285"},{"range":"32096","text":"24285"},{"range":"32097","text":"24285"},{"range":"32098","text":"24285"},{"range":"32099","text":"24285"},{"range":"32100","text":"26508"},{"range":"32101","text":"24285"},{"range":"32102","text":"24285"},{"range":"32103","text":"24285"},{"range":"32104","text":"24285"},{"range":"32105","text":"24285"},"React Hook useEffect has missing dependencies: 'errorMessage' and 'templateVersion'. Either include them or remove the dependency array.",["32106"],{"range":"32107","text":"24285"},{"range":"32108","text":"24285"},{"range":"32109","text":"24285"},{"range":"32110","text":"24285"},{"range":"32111","text":"24285"},{"range":"32112","text":"24285"},{"range":"32113","text":"24285"},{"range":"32114","text":"24285"},{"range":"32115","text":"24285"},{"range":"32116","text":"24285"},{"range":"32117","text":"24285"},{"range":"32118","text":"24285"},{"range":"32119","text":"26508"},{"range":"32120","text":"24285"},{"range":"32121","text":"24285"},{"range":"32122","text":"24285"},{"range":"32123","text":"24285"},{"range":"32124","text":"24285"},"React Hook useEffect has missing dependencies: 'customErrorMessage', 't', and 'templateVersion'. Either include them or remove the dependency array. If 'setError' needs the current value of 'customErrorMessage', you can also switch to useReducer instead of useState and read 'customErrorMessage' in the reducer.",["32125"],{"range":"32126","text":"24285"},{"range":"32127","text":"24285"},{"range":"32128","text":"24285"},{"range":"32129","text":"24285"},{"range":"32130","text":"24285"},{"range":"32131","text":"24285"},{"range":"32132","text":"24285"},{"range":"32133","text":"24285"},{"range":"32134","text":"24285"},{"range":"32135","text":"24285"},{"range":"32136","text":"24285"},{"range":"32137","text":"24285"},{"range":"32138","text":"24285"},{"range":"32139","text":"24285"},{"range":"32140","text":"24285"},{"range":"32141","text":"24285"},{"range":"32142","text":"24285"},"'route' is never reassigned. Use 'const' instead.",{"range":"32143","text":"32144"},{"range":"32145","text":"24285"},{"range":"32146","text":"24285"},{"range":"32147","text":"24285"},{"range":"32148","text":"24285"},{"range":"32149","text":"24285"},{"range":"32150","text":"24285"},{"range":"32151","text":"24285"},{"range":"32152","text":"24285"},"React Hook useEffect has missing dependencies: 'currentUser?.isRegionalReviewManager', 'findMatchingPathTemplate', 'jurisdictionId', 'navigate', and 'pathname'. Either include them or remove the dependency array.",["32153"],{"range":"32154","text":"24285"},{"range":"32155","text":"28637"},{"range":"32156","text":"24285"},{"range":"32157","text":"24285"},{"range":"32158","text":"24285"},{"range":"32159","text":"24285"},{"range":"32160","text":"24285"},{"range":"32161","text":"24285"},{"range":"32162","text":"24285"},{"range":"32163","text":"24285"},{"range":"32164","text":"24285"},"React Hook useEffect has missing dependencies: 'fetchJurisdiction', 'jurisdictionId', 'setCurrentJurisdiction', 'setCurrentJurisdictionBySlug', and 't'. Either include them or remove the dependency array.",["32165"],{"range":"32166","text":"24285"},{"range":"32167","text":"24285"},{"range":"32168","text":"24285"},"'permitApplication' is never reassigned. Use 'const' instead.",{"range":"32169","text":"32170"},"React Hook useEffect has missing dependencies: 'fetchPermitApplication', 'permitApplicationId', 'review', 'setCurrentPermitApplication', and 't'. Either include them or remove the dependency array.",["32171"],{"range":"32172","text":"24285"},{"range":"32173","text":"24285"},{"range":"32174","text":"24285"},{"range":"32175","text":"24285"},{"range":"32176","text":"24285"},"React Hook useEffect has a missing dependency: 'fetchPermitClassifications'. Either include it or remove the dependency array.",["32177"],{"range":"32178","text":"24285"},{"range":"32179","text":"24285"},{"range":"32180","text":"24285"},{"range":"32181","text":"24285"},{"range":"32182","text":"24285"},{"range":"32183","text":"24285"},{"range":"32184","text":"24285"},{"range":"32185","text":"24285"},{"range":"32186","text":"24285"},{"range":"32187","text":"24285"},{"range":"32188","text":"24285"},{"range":"32189","text":"24285"},{"range":"32190","text":"24285"},{"range":"32191","text":"26508"},{"range":"32192","text":"24285"},{"range":"32193","text":"24285"},{"range":"32194","text":"24285"},{"range":"32195","text":"24285"},{"range":"32196","text":"24285"},{"range":"32197","text":"24285"},"React Hook useEffect has missing dependencies: 'error', 'fetchPermitTypeOptions', 'permitTypeOptions', and 't'. Either include them or remove the dependency array.",["32198"],{"range":"32199","text":"24285"},{"range":"32200","text":"24285"},"'generatePath' is defined but never used.",["32201"],"'currentUser' is assigned a value but never used.","'setCurrentProgramBySlug' is assigned a value but never used.","'findMatchingPathTemplate' is assigned a value but never used.",{"range":"32202","text":"32144"},"React Hook useEffect has missing dependencies: 'fetchProgram', 'programId', 'setCurrentProgram', and 't'. Either include them or remove the dependency array.",["32203"],{"range":"32204","text":"24285"},{"range":"32205","text":"24285"},{"range":"32206","text":"24285"},{"range":"32207","text":"24285"},{"range":"32208","text":"24285"},{"range":"32209","text":"24285"},{"range":"32210","text":"24285"},{"range":"32211","text":"24285"},{"range":"32212","text":"24285"},{"range":"32213","text":"24285"},{"range":"32214","text":"24285"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/hooks/resources/use-requirement-template.ts:17:7\n  15 |   useEffect(() => {\n  16 |     if (!isUUID(requirementTemplateId)) {\n> 17 |       setError(new Error(t(\"errors.fetchRequirementTemplate\")))\n     |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  18 |       import.meta.env.DEV &&\n  19 |         console.error(\"requirement template id supplied to useRequirementTemplate hook is not a uuid\")\n  20 |       return",{"range":"32215","text":"24285"},{"range":"32216","text":"24285"},{"range":"32217","text":"24285"},{"range":"32218","text":"24461"},{"range":"32219","text":"24285"},{"range":"32220","text":"24285"},{"range":"32221","text":"24285"},{"range":"32222","text":"24285"},{"range":"32223","text":"24285"},"React Hook useEffect has missing dependencies: 'requirementTemplateStore' and 't'. Either include them or remove the dependency array.",["32224"],{"range":"32225","text":"24285"},{"range":"32226","text":"24285"},{"range":"32227","text":"24285"},{"range":"32228","text":"24285"},{"range":"32229","text":"24285"},{"range":"32230","text":"24285"},{"range":"32231","text":"24285"},{"range":"32232","text":"24285"},{"range":"32233","text":"24285"},{"range":"32234","text":"24285"},{"range":"32235","text":"24285"},{"range":"32236","text":"24285"},{"range":"32237","text":"24285"},{"range":"32238","text":"24285"},{"range":"32239","text":"24285"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/hooks/resources/use-template-version.ts:18:7\n  16 |   useEffect(() => {\n  17 |     if (!isUUID(templateVersionId)) {\n> 18 |       setError(new Error(t(\"errors.fetchTemplateVersion\")))\n     |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  19 |       import.meta.env.DEV && console.error(\"template version id supplied to useTemplateVersion hook is not a uuid\")\n  20 |       return\n  21 |     }",{"range":"32240","text":"24285"},{"range":"32241","text":"24285"},{"range":"32242","text":"24285"},{"range":"32243","text":"24461"},{"range":"32244","text":"24285"},{"range":"32245","text":"24285"},{"range":"32246","text":"24285"},{"range":"32247","text":"24285"},{"range":"32248","text":"24285"},"React Hook useEffect has missing dependencies: 'customErrorMessage', 't', and 'templateVersionStore'. Either include them or remove the dependency array. If 'setError' needs the current value of 'customErrorMessage', you can also switch to useReducer instead of useState and read 'customErrorMessage' in the reducer.",["32249"],{"range":"32250","text":"24285"},{"range":"32251","text":"24285"},{"range":"32252","text":"24285"},{"range":"32253","text":"24285"},{"range":"32254","text":"24285"},{"range":"32255","text":"24285"},{"range":"32256","text":"24285"},{"range":"32257","text":"24285"},{"range":"32258","text":"24285"},{"range":"32259","text":"24285"},{"range":"32260","text":"24285"},{"range":"32261","text":"24285"},{"range":"32262","text":"24285"},{"range":"32263","text":"24285"},{"range":"32264","text":"24285"},{"range":"32265","text":"28637"},{"range":"32266","text":"24285"},{"range":"32267","text":"24285"},{"range":"32268","text":"24285"},{"range":"32269","text":"24285"},{"range":"32270","text":"24285"},{"range":"32271","text":"24285"},"React Hook useEffect has missing dependencies: 'customErrorMessage', 'earlyAccess', 'fetchTemplateVersions', 'isPublic', 'status', and 't'. Either include them or remove the dependency array.",["32272"],{"range":"32273","text":"24285"},{"range":"32274","text":"24285"},{"range":"32275","text":"24285"},{"range":"32276","text":"24285"},{"range":"32277","text":"24285"},{"range":"32278","text":"24285"},{"range":"32279","text":"24285"},{"range":"32280","text":"24285"},{"range":"32281","text":"24285"},{"range":"32282","text":"24285"},{"range":"32283","text":"24285"},{"range":"32284","text":"28637"},{"range":"32285","text":"24285"},{"range":"32286","text":"24285"},{"range":"32287","text":"24285"},{"range":"32288","text":"24285"},{"range":"32289","text":"24285"},"'_e' is defined but never used.",{"range":"32290","text":"24285"},{"range":"32291","text":"24285"},{"range":"32292","text":"24285"},"React Hook useEffect has missing dependencies: 'currentUser', 'customErrorMessage', 't', and 'userStore'. Either include them or remove the dependency array. If 'setError' needs the current value of 'customErrorMessage', you can also switch to useReducer instead of useState and read 'customErrorMessage' in the reducer.",["32293"],{"range":"32294","text":"24285"},{"range":"32295","text":"24285"},{"range":"32296","text":"24285"},{"range":"32297","text":"24285"},{"range":"32298","text":"24285"},{"range":"32299","text":"24285"},{"range":"32300","text":"24285"},{"range":"32301","text":"24285"},"React Hook useEffect has a missing dependency: 'uiStore'. Either include it or remove the dependency array.",["32302"],{"range":"32303","text":"24285"},{"range":"32304","text":"24285"},{"range":"32305","text":"24285"},{"range":"32306","text":"24285"},{"range":"32307","text":"24285"},{"range":"32308","text":"24285"},{"range":"32309","text":"24285"},"'id' is never reassigned. Use 'const' instead.",{"range":"32310","text":"32311"},{"range":"32312","text":"24285"},{"range":"32313","text":"24285"},{"range":"32314","text":"24285"},{"range":"32315","text":"24285"},{"range":"32316","text":"24285"},{"range":"32317","text":"24285"},{"range":"32318","text":"24285"},{"range":"32319","text":"24285"},{"range":"32320","text":"24285"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/hooks/use-notification-popover.tsx:32:7\n  30 |   useEffect(() => {\n  31 |     if (isOpen && unreadNotificationsCount > newNotificationCount) {\n> 32 |       setNewNotificationCount(unreadNotificationsCount);\n     |       ^^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  33 |     }\n  34 |   }, [isOpen, unreadNotificationsCount, newNotificationCount]);\n  35 |",{"range":"32321","text":"24285"},{"range":"32322","text":"24285"},{"range":"32323","text":"24285"},{"range":"32324","text":"24285"},{"range":"32325","text":"24285"},{"range":"32326","text":"24285"},"Error: Cannot access variable before it is declared\n\n`handleKeyDown` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/hooks/use-quick-submit.ts:11:42\n   9 | export function useQuickSubmit({ isDisabled, formRef, onSubmit }: TUseQuickSubmitProps) {\n  10 |   useEffect(() => {\n> 11 |     document.addEventListener(\"keydown\", handleKeyDown)\n     |                                          ^^^^^^^^^^^^^ `handleKeyDown` accessed before it is declared\n  12 |     return () => document.removeEventListener(\"keydown\", handleKeyDown)\n  13 |   })\n  14 |\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/hooks/use-quick-submit.ts:15:3\n  13 |   })\n  14 |\n> 15 |   const handleKeyDown = (e) => {\n     |   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 16 |     const isFocused = formRef.current?.contains(document.activeElement)\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 17 |     if (e.keyCode === 13 && (e.metaKey || e.cntrlKey) && !isDisabled && isFocused) {\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 18 |       onSubmit()\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 19 |     }\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 20 |   }\n     | ^^^^ `handleKeyDown` is declared here\n  21 | }\n  22 |",{"range":"32327","text":"24285"},{"range":"32328","text":"24285"},{"range":"32329","text":"24285"},{"range":"32330","text":"24285"},{"range":"32331","text":"24285"},{"range":"32332","text":"24285"},{"range":"32333","text":"24285"},{"range":"32334","text":"24285"},{"range":"32335","text":"24285"},{"range":"32336","text":"24285"},{"range":"32337","text":"24285"},{"range":"32338","text":"24285"},{"range":"32339","text":"24285"},{"range":"32340","text":"24285"},{"range":"32341","text":"24285"},"React Hook useEffect has missing dependencies: 'resetCurrentPermitApplication' and 'resetCurrentProgram'. Either include them or remove the dependency array.",["32342"],"React Hook useEffect has missing dependencies: 'dependencyArray' and 'searchModel'. Either include them or remove the dependency array.",["32343"],"React Hook useEffect has a spread element in its dependency array. This means we can't statically verify whether you've passed the correct dependencies.","SpreadElement","'defaultValue' is defined but never used.",{"range":"32344","text":"24285"},{"range":"32345","text":"24285"},{"range":"32346","text":"24285"},{"range":"32347","text":"24285"},{"range":"32348","text":"24285"},{"range":"32349","text":"24285"},{"range":"32350","text":"24285"},{"range":"32351","text":"24285"},{"range":"32352","text":"24285"},{"range":"32353","text":"24285"},{"range":"32354","text":"24285"},"'assign' is defined but never used.",["32355"],{"range":"32356","text":"32357"},"require-yield","This generator function does not have 'yield'.","FunctionExpression","missingYield",["32358"],{"range":"32359","text":"24285"},{"range":"32360","text":"24285"},"@typescript-eslint/no-namespace","ES2015 module syntax is preferred over namespaces.","TSModuleDeclaration","moduleSyntaxIsPreferred",{"range":"32361","text":"24285"},{"range":"32362","text":"24285"},{"range":"32363","text":"24285"},{"range":"32364","text":"24285"},{"range":"32365","text":"24285"},{"range":"32366","text":"24285"},{"range":"32367","text":"24285"},{"range":"32368","text":"24285"},{"range":"32369","text":"24285"},{"range":"32370","text":"24285"},{"range":"32371","text":"24285"},{"range":"32372","text":"24285"},{"range":"32373","text":"24285"},{"range":"32374","text":"24285"},{"range":"32375","text":"24285"},{"range":"32376","text":"24285"},{"range":"32377","text":"24285"},{"range":"32378","text":"24285"},{"range":"32379","text":"24285"},["32380"],{"range":"32381","text":"24285"},{"range":"32382","text":"24285"},{"range":"32383","text":"24285"},{"range":"32384","text":"24285"},{"range":"32385","text":"24285"},["32386"],"'IUser' is defined but never used.",["32387"],["32388"],{"range":"32389","text":"24285"},{"range":"32390","text":"24285"},{"range":"32391","text":"24285"},{"range":"32392","text":"24285"},{"range":"32393","text":"24285"},{"range":"32394","text":"24285"},{"range":"32395","text":"24285"},{"range":"32396","text":"24285"},{"range":"32397","text":"24285"},{"range":"32398","text":"24285"},{"range":"32399","text":"24285"},{"range":"32400","text":"24285"},{"range":"32401","text":"24285"},{"range":"32402","text":"24285"},{"range":"32403","text":"24285"},{"range":"32404","text":"24285"},{"range":"32405","text":"24285"},{"range":"32406","text":"24285"},{"range":"32407","text":"24285"},{"range":"32408","text":"24285"},{"range":"32409","text":"24285"},["32410"],"'SupportRequestModel' is defined but never used.",["32411"],"'ProgramModel' is defined but never used.",["32412"],"'UserModel' is defined but never used.",["32413"],"'ContractorModel' is defined but never used.",["32414"],"'id' is defined but never used.","'_key' is defined but never used.","'parentKey' is defined but never used.",["32415"],{"range":"32416","text":"24285"},{"range":"32417","text":"24285"},{"range":"32418","text":"24285"},{"range":"32419","text":"24285"},{"range":"32420","text":"24285"},{"range":"32421","text":"24285"},{"range":"32422","text":"24285"},{"range":"32423","text":"24285"},["32424"],{"range":"32425","text":"24285"},{"range":"32426","text":"24285"},{"range":"32427","text":"24285"},{"range":"32428","text":"24285"},{"range":"32429","text":"24285"},{"range":"32430","text":"24285"},"'self' is defined but never used.",{"range":"32431","text":"24285"},{"range":"32432","text":"24285"},{"range":"32433","text":"24285"},{"range":"32434","text":"24285"},{"range":"32435","text":"24285"},{"range":"32436","text":"24285"},{"range":"32437","text":"24285"},{"range":"32438","text":"24285"},{"range":"32439","text":"24285"},{"range":"32440","text":"24285"},["32441"],{"range":"32442","text":"24285"},{"range":"32443","text":"24285"},{"range":"32444","text":"24285"},{"range":"32445","text":"24285"},{"range":"32446","text":"24285"},{"range":"32447","text":"24285"},{"range":"32448","text":"24285"},{"range":"32449","text":"24285"},{"range":"32450","text":"24285"},{"range":"32451","text":"24285"},{"range":"32452","text":"24285"},{"range":"32453","text":"24285"},{"range":"32454","text":"24285"},{"range":"32455","text":"24285"},"'localSystemMapping' is defined but never used.",{"range":"32456","text":"24285"},{"range":"32457","text":"24285"},{"range":"32458","text":"24285"},{"range":"32459","text":"24285"},{"range":"32460","text":"24285"},{"range":"32461","text":"24285"},{"range":"32462","text":"24285"},{"range":"32463","text":"24285"},["32464"],{"range":"32465","text":"24285"},{"range":"32466","text":"24285"},{"range":"32467","text":"24285"},"'requirementsMapping' is never reassigned. Use 'const' instead.",{"range":"32468","text":"32469"},{"range":"32470","text":"24285"},"'sku' is never reassigned. Use 'const' instead.",{"range":"32471","text":"32472"},"'requirementBlockMapping' is never reassigned. Use 'const' instead.",{"range":"32473","text":"32472"},{"range":"32474","text":"28637"},{"range":"32475","text":"24285"},{"range":"32476","text":"32477"},{"range":"32478","text":"24285"},{"range":"32479","text":"24285"},{"range":"32480","text":"24285"},["32481"],{"range":"32482","text":"24285"},{"range":"32483","text":"24285"},{"range":"32484","text":"24285"},["32485"],{"range":"32486","text":"24285"},{"range":"32487","text":"24285"},{"range":"32488","text":"24285"},{"range":"32489","text":"24285"},{"range":"32490","text":"24285"},{"range":"32491","text":"24285"},{"range":"32492","text":"24285"},{"range":"32493","text":"24285"},{"range":"32494","text":"24285"},{"range":"32495","text":"24285"},{"range":"32496","text":"24285"},{"range":"32497","text":"24285"},{"range":"32498","text":"24285"},{"range":"32499","text":"24285"},{"range":"32500","text":"24285"},{"range":"32501","text":"24285"},{"range":"32502","text":"24285"},{"range":"32503","text":"24285"},{"range":"32504","text":"24285"},{"range":"32505","text":"24285"},{"range":"32506","text":"24285"},{"range":"32507","text":"24285"},{"range":"32508","text":"24285"},{"range":"32509","text":"24285"},{"range":"32510","text":"24285"},{"range":"32511","text":"24285"},{"range":"32512","text":"24285"},{"range":"32513","text":"24285"},{"range":"32514","text":"24285"},{"range":"32515","text":"24285"},{"range":"32516","text":"24285"},{"range":"32517","text":"24285"},{"range":"32518","text":"24285"},{"range":"32519","text":"24285"},{"range":"32520","text":"24285"},{"range":"32521","text":"24285"},{"range":"32522","text":"24285"},{"range":"32523","text":"24285"},{"range":"32524","text":"24285"},{"range":"32525","text":"24285"},{"range":"32526","text":"24285"},{"range":"32527","text":"24285"},{"range":"32528","text":"24285"},{"range":"32529","text":"24285"},{"range":"32530","text":"24285"},{"range":"32531","text":"24285"},{"range":"32532","text":"24285"},{"range":"32533","text":"24285"},{"range":"32534","text":"24285"},{"range":"32535","text":"24285"},{"range":"32536","text":"24285"},{"range":"32537","text":"24285"},{"range":"32538","text":"24285"},{"range":"32539","text":"24285"},{"range":"32540","text":"24285"},{"range":"32541","text":"24285"},{"range":"32542","text":"24285"},{"range":"32543","text":"24285"},{"range":"32544","text":"24285"},{"range":"32545","text":"24285"},{"range":"32546","text":"24285"},{"range":"32547","text":"24285"},{"range":"32548","text":"24285"},{"range":"32549","text":"24285"},["32550"],["32551"],{"range":"32552","text":"24285"},{"range":"32553","text":"24285"},{"range":"32554","text":"24285"},["32555"],["32556"],["32557"],["32558"],["32559"],["32560"],["32561"],{"range":"32562","text":"24285"},{"range":"32563","text":"24285"},{"range":"32564","text":"24285"},{"range":"32565","text":"24285"},{"range":"32566","text":"24285"},["32567"],"'Instance' is defined but never used.",["32568"],"'flow' is defined but never used.",["32569"],"'toGenerator' is defined but never used.",["32570"],["32571"],["32572"],["32573"],["32574"],["32575"],["32576"],"'EProgramUserGroupType' is defined but never used.",["32577"],"'TLatLngTuple' is defined but never used.",["32578"],["32579"],{"range":"32580","text":"24285"},{"range":"32581","text":"24285"},{"range":"32582","text":"24285"},{"range":"32583","text":"24285"},{"range":"32584","text":"24285"},{"range":"32585","text":"24285"},{"range":"32586","text":"24285"},{"range":"32587","text":"24285"},{"range":"32588","text":"24285"},{"range":"32589","text":"24285"},{"range":"32590","text":"24285"},{"range":"32591","text":"24285"},{"range":"32592","text":"24285"},{"range":"32593","text":"24285"},{"range":"32594","text":"24285"},{"range":"32595","text":"24285"},{"range":"32596","text":"24285"},{"range":"32597","text":"24285"},{"range":"32598","text":"24285"},{"range":"32599","text":"24285"},{"range":"32600","text":"24285"},{"range":"32601","text":"24285"},{"range":"32602","text":"24285"},["32603"],{"range":"32604","text":"24285"},{"range":"32605","text":"24285"},{"range":"32606","text":"24285"},{"range":"32607","text":"24285"},["32608"],["32609"],{"range":"32610","text":"24285"},{"range":"32611","text":"24285"},{"range":"32612","text":"24285"},{"range":"32613","text":"24285"},{"range":"32614","text":"24285"},{"range":"32615","text":"24285"},{"range":"32616","text":"24285"},{"range":"32617","text":"24285"},{"range":"32618","text":"24285"},{"range":"32619","text":"24285"},{"range":"32620","text":"24285"},{"range":"32621","text":"24285"},{"range":"32622","text":"24285"},{"range":"32623","text":"24285"},{"range":"32624","text":"24285"},{"range":"32625","text":"24285"},{"range":"32626","text":"24285"},{"range":"32627","text":"24285"},{"range":"32628","text":"24285"},{"range":"32629","text":"24285"},{"range":"32630","text":"24285"},{"range":"32631","text":"24285"},{"range":"32632","text":"24285"},{"range":"32633","text":"24285"},{"range":"32634","text":"24285"},{"range":"32635","text":"24285"},{"range":"32636","text":"24285"},{"range":"32637","text":"24285"},{"range":"32638","text":"24285"},{"range":"32639","text":"24285"},{"range":"32640","text":"24285"},{"range":"32641","text":"24285"},{"range":"32642","text":"24285"},{"range":"32643","text":"24285"},{"range":"32644","text":"24285"},{"range":"32645","text":"24285"},{"range":"32646","text":"24285"},["32647"],{"range":"32648","text":"24285"},{"range":"32649","text":"24285"},{"range":"32650","text":"24285"},{"range":"32651","text":"24285"},{"range":"32652","text":"24285"},{"range":"32653","text":"24285"},{"range":"32654","text":"24285"},{"range":"32655","text":"24285"},{"range":"32656","text":"24285"},{"range":"32657","text":"24285"},{"range":"32658","text":"24285"},{"range":"32659","text":"24285"},{"range":"32660","text":"24285"},["32661"],["32662"],{"range":"32663","text":"24285"},{"range":"32664","text":"24285"},{"range":"32665","text":"24285"},{"range":"32666","text":"24285"},{"range":"32667","text":"24285"},{"range":"32668","text":"24285"},{"range":"32669","text":"24285"},"@typescript-eslint/no-wrapper-object-types","Prefer using the pr