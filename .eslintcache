,"text":"24285"},{"range":"30782","text":"24285"},{"range":"30783","text":"24285"},{"range":"30784","text":"24285"},{"range":"30785","text":"24285"},{"range":"30786","text":"24285"},{"range":"30787","text":"24285"},{"range":"30788","text":"24285"},{"range":"30789","text":"24285"},{"range":"30790","text":"24285"},{"range":"30791","text":"24285"},{"range":"30792","text":"24285"},{"range":"30793","text":"24285"},{"range":"30794","text":"24285"},{"range":"30795","text":"24285"},{"range":"30796","text":"24285"},{"range":"30797","text":"24285"},{"range":"30798","text":"24285"},{"range":"30799","text":"24285"},{"range":"30800","text":"24285"},{"range":"30801","text":"24285"},{"range":"30802","text":"24285"},{"range":"30803","text":"24285"},{"range":"30804","text":"24285"},{"range":"30805","text":"24285"},{"range":"30806","text":"24285"},{"range":"30807","text":"24285"},"'newValue' is never reassigned. Use 'const' instead.",{"range":"30808","text":"30809"},{"range":"30810","text":"24285"},{"range":"30811","text":"24285"},{"range":"30812","text":"24285"},{"range":"30813","text":"24285"},{"range":"30814","text":"24285"},{"range":"30815","text":"24285"},{"range":"30816","text":"24285"},{"range":"30817","text":"24285"},{"range":"30818","text":"24285"},{"range":"30819","text":"24285"},{"range":"30820","text":"24285"},{"range":"30821","text":"30822"},{"range":"30823","text":"24285"},{"range":"30824","text":"24285"},{"range":"30825","text":"24285"},{"range":"30826","text":"24285"},{"range":"30827","text":"24285"},{"range":"30828","text":"24285"},{"range":"30829","text":"24285"},{"range":"30830","text":"24285"},{"range":"30831","text":"24285"},{"range":"30832","text":"24285"},{"range":"30833","text":"24285"},{"range":"30834","text":"24285"},{"range":"30835","text":"24285"},{"range":"30836","text":"24285"},{"range":"30837","text":"24285"},{"range":"30838","text":"24285"},{"range":"30839","text":"24285"},{"range":"30840","text":"24285"},{"range":"30841","text":"24285"},{"range":"30842","text":"24285"},{"range":"30843","text":"24285"},{"range":"30844","text":"24285"},{"range":"30845","text":"24285"},{"range":"30846","text":"24285"},{"range":"30847","text":"24285"},{"range":"30848","text":"24285"},{"range":"30849","text":"24285"},"Error: Cannot access variable before it is declared\n\n`reset` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/contact/create-edit-contact-modal.tsx:79:5\n  77 |\n  78 |   useEffect(() => {\n> 79 |     reset(getDefaultValues())\n     |     ^^^^^ `reset` accessed before it is declared\n  80 |   }, [contact])\n  81 |\n  82 |   const formMethods = useForm<TContactFormData>({\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/contact/create-edit-contact-modal.tsx:87:36\n  85 |   })\n  86 |\n> 87 |   const { handleSubmit, formState, reset } = formMethods\n     |                                    ^^^^^ `reset` is declared here\n  88 |   const { isSubmitting, isValid } = formState\n  89 |\n  90 |   const onSubmit = async (formData: TContactFormData) => {",{"range":"30850","text":"24285"},["30851"],{"range":"30852","text":"24285"},{"range":"30853","text":"24285"},{"range":"30854","text":"24285"},{"range":"30855","text":"24285"},{"range":"30856","text":"24285"},{"range":"30857","text":"24285"},{"range":"30858","text":"24285"},{"range":"30859","text":"24285"},{"range":"30860","text":"24285"},{"range":"30861","text":"24285"},{"range":"30862","text":"24285"},{"range":"30863","text":"24285"},{"range":"30864","text":"24285"},{"range":"30865","text":"24285"},{"range":"30866","text":"24285"},{"range":"30867","text":"24285"},"react/display-name","Component definition is missing display name","noDisplayName","jsx-a11y/aria-role","Elements with ARIA roles must use a valid, non-abstract ARIA role.",{"range":"30868","text":"24285"},{"range":"30869","text":"24285"},{"range":"30870","text":"24285"},{"range":"30871","text":"24285"},{"range":"30872","text":"24285"},{"range":"30873","text":"24285"},{"range":"30874","text":"24285"},{"range":"30875","text":"24285"},{"range":"30876","text":"24285"},{"range":"30877","text":"24285"},{"range":"30878","text":"24285"},{"range":"30879","text":"24285"},{"range":"30880","text":"24285"},{"range":"30881","text":"24285"},{"range":"30882","text":"24285"},{"range":"30883","text":"24285"},{"range":"30884","text":"24285"},{"range":"30885","text":"24285"},{"range":"30886","text":"24285"},{"range":"30887","text":"24285"},{"range":"30888","text":"24285"},{"range":"30889","text":"24285"},{"range":"30890","text":"24285"},{"range":"30891","text":"24285"},{"range":"30892","text":"24285"},{"range":"30893","text":"24285"},{"range":"30894","text":"24285"},{"range":"30895","text":"24285"},{"range":"30896","text":"24285"},{"range":"30897","text":"24285"},{"range":"30898","text":"24285"},{"range":"30899","text":"24285"},{"range":"30900","text":"24285"},{"range":"30901","text":"24285"},"'restSaveButtonProps' is assigned a value but never used.",{"range":"30902","text":"24285"},"'restCancelButtonProps' is assigned a value but never used.",{"range":"30903","text":"24285"},{"range":"30904","text":"24285"},{"range":"30905","text":"24285"},{"range":"30906","text":"24285"},{"range":"30907","text":"24285"},"'getSubmitButtonProps' is assigned a value but never used.","'getCancelButtonProps' is assigned a value but never used.",{"range":"30908","text":"24285"},{"range":"30909","text":"24285"},{"range":"30910","text":"24285"},"'borderEndEndRadius' is defined but never used.",{"range":"30911","text":"24285"},{"range":"30912","text":"24285"},{"range":"30913","text":"24285"},{"range":"30914","text":"24285"},{"range":"30915","text":"24285"},{"range":"30916","text":"24285"},{"range":"30917","text":"24285"},{"range":"30918","text":"24285"},["30919"],{"range":"30920","text":"24285"},{"range":"30921","text":"24285"},{"range":"30922","text":"24285"},{"range":"30923","text":"24285"},{"range":"30924","text":"24285"},{"range":"30925","text":"24285"},{"range":"30926","text":"24285"},{"range":"30927","text":"24285"},{"range":"30928","text":"24285"},{"range":"30929","text":"24285"},{"range":"30930","text":"24285"},{"range":"30931","text":"24285"},{"range":"30932","text":"24285"},{"range":"30933","text":"24285"},{"range":"30934","text":"24285"},{"range":"30935","text":"24285"},{"range":"30936","text":"24285"},{"range":"30937","text":"24285"},{"range":"30938","text":"24285"},{"range":"30939","text":"24285"},{"range":"30940","text":"24285"},{"range":"30941","text":"24285"},{"range":"30942","text":"24285"},{"range":"30943","text":"24285"},{"range":"30944","text":"24285"},{"range":"30945","text":"24285"},{"range":"30946","text":"24285"},{"range":"30947","text":"24285"},{"range":"30948","text":"24285"},{"range":"30949","text":"24285"},{"range":"30950","text":"24285"},{"range":"30951","text":"24285"},{"range":"30952","text":"24285"},{"range":"30953","text":"24285"},{"range":"30954","text":"24285"},{"range":"30955","text":"24285"},{"range":"30956","text":"24285"},{"range":"30957","text":"24285"},{"range":"30958","text":"24285"},{"range":"30959","text":"24285"},{"range":"30960","text":"24285"},"'node' is never reassigned. Use 'const' instead.",{"range":"30961","text":"30962"},{"range":"30963","text":"24285"},{"range":"30964","text":"24285"},{"range":"30965","text":"24285"},{"range":"30966","text":"24285"},{"range":"30967","text":"24285"},{"range":"30968","text":"24285"},{"range":"30969","text":"24285"},{"range":"30970","text":"24285"},{"range":"30971","text":"24285"},{"range":"30972","text":"24285"},{"range":"30973","text":"24285"},{"range":"30974","text":"24285"},{"range":"30975","text":"24285"},{"range":"30976","text":"24285"},{"range":"30977","text":"24285"},{"range":"30978","text":"24285"},{"range":"30979","text":"24285"},{"range":"30980","text":"24285"},{"range":"30981","text":"24285"},{"range":"30982","text":"24285"},{"range":"30983","text":"24285"},{"range":"30984","text":"24285"},{"range":"30985","text":"24285"},{"range":"30986","text":"24285"},{"range":"30987","text":"24285"},{"range":"30988","text":"24285"},{"range":"30989","text":"24285"},{"range":"30990","text":"24285"},{"range":"30991","text":"24285"},{"range":"30992","text":"24285"},{"range":"30993","text":"24285"},{"range":"30994","text":"24285"},{"range":"30995","text":"24285"},{"range":"30996","text":"24285"},{"range":"30997","text":"24285"},{"range":"30998","text":"24285"},{"range":"30999","text":"24285"},{"range":"31000","text":"24285"},{"range":"31001","text":"24285"},{"range":"31002","text":"24285"},{"range":"31003","text":"24285"},{"range":"31004","text":"24285"},{"range":"31005","text":"24285"},{"range":"31006","text":"24285"},{"range":"31007","text":"24285"},{"range":"31008","text":"24285"},{"range":"31009","text":"24285"},{"range":"31010","text":"24285"},{"range":"31011","text":"24285"},{"range":"31012","text":"24285"},{"range":"31013","text":"24285"},{"range":"31014","text":"24285"},{"range":"31015","text":"24285"},{"range":"31016","text":"24285"},{"range":"31017","text":"24285"},{"range":"31018","text":"24285"},{"range":"31019","text":"24285"},{"range":"31020","text":"24285"},{"range":"31021","text":"24285"},{"range":"31022","text":"24285"},{"range":"31023","text":"24285"},{"range":"31024","text":"24285"},{"range":"31025","text":"24285"},{"range":"31026","text":"24285"},{"range":"31027","text":"24285"},{"range":"31028","text":"24285"},{"range":"31029","text":"24285"},{"range":"31030","text":"24285"},{"range":"31031","text":"24285"},{"range":"31032","text":"24285"},{"range":"31033","text":"24285"},{"range":"31034","text":"24285"},{"range":"31035","text":"24285"},{"range":"31036","text":"24285"},{"range":"31037","text":"24285"},{"range":"31038","text":"24285"},{"range":"31039","text":"24285"},{"range":"31040","text":"24285"},{"range":"31041","text":"24285"},{"range":"31042","text":"24285"},{"range":"31043","text":"24285"},{"range":"31044","text":"24285"},{"range":"31045","text":"24285"},{"range":"31046","text":"24285"},{"range":"31047","text":"24285"},{"range":"31048","text":"24285"},{"range":"31049","text":"24285"},{"range":"31050","text":"24285"},{"range":"31051","text":"24285"},{"range":"31052","text":"24285"},{"range":"31053","text":"24285"},{"range":"31054","text":"24285"},{"range":"31055","text":"24285"},{"range":"31056","text":"24285"},{"range":"31057","text":"24285"},{"range":"31058","text":"24285"},{"range":"31059","text":"24285"},{"range":"31060","text":"24285"},{"range":"31061","text":"24285"},{"range":"31062","text":"24285"},{"range":"31063","text":"24285"},{"range":"31064","text":"24285"},{"range":"31065","text":"24285"},{"range":"31066","text":"24285"},{"range":"31067","text":"24285"},{"range":"31068","text":"24285"},{"range":"31069","text":"24285"},{"range":"31070","text":"24285"},{"range":"31071","text":"24285"},{"range":"31072","text":"24285"},{"range":"31073","text":"24285"},{"range":"31074","text":"24285"},{"range":"31075","text":"24285"},{"range":"31076","text":"24285"},{"range":"31077","text":"24285"},{"range":"31078","text":"24285"},{"range":"31079","text":"24285"},{"range":"31080","text":"24285"},{"range":"31081","text":"24285"},{"range":"31082","text":"24285"},{"range":"31083","text":"24285"},{"range":"31084","text":"24285"},{"range":"31085","text":"24285"},{"range":"31086","text":"24285"},"'delta' is defined but never used.","'source' is defined but never used.","'editor' is defined but never used.",{"range":"31087","text":"24285"},{"range":"31088","text":"24285"},"'href' is never reassigned. Use 'const' instead.",{"range":"31089","text":"31090"},{"range":"31091","text":"24285"},{"range":"31092","text":"24285"},{"range":"31093","text":"24285"},{"range":"31094","text":"24285"},{"range":"31095","text":"24285"},{"range":"31096","text":"24285"},{"range":"31097","text":"24285"},"React Hook useMemo has missing dependencies: 'richText' and 'shouldContainRichTextToolbarItem'. Either include them or remove the dependency array. If 'shouldContainRichTextToolbarItem' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["31098"],{"range":"31099","text":"24285"},{"range":"31100","text":"24285"},{"range":"31101","text":"24285"},{"range":"31102","text":"24285"},{"range":"31103","text":"24285"},{"range":"31104","text":"24285"},{"range":"31105","text":"24285"},{"range":"31106","text":"24285"},{"range":"31107","text":"24285"},{"range":"31108","text":"24285"},{"range":"31109","text":"24285"},"'SavableEditor' is assigned a value but never used.",{"range":"31110","text":"24285"},{"range":"31111","text":"24285"},{"range":"31112","text":"24285"},{"range":"31113","text":"24285"},{"range":"31114","text":"24285"},{"range":"31115","text":"24285"},{"range":"31116","text":"24285"},{"range":"31117","text":"24285"},{"range":"31118","text":"24285"},{"range":"31119","text":"24285"},{"range":"31120","text":"24285"},{"range":"31121","text":"24285"},{"range":"31122","text":"24285"},{"range":"31123","text":"24285"},{"range":"31124","text":"24285"},{"range":"31125","text":"24285"},{"range":"31126","text":"24285"},{"range":"31127","text":"24285"},{"range":"31128","text":"24285"},{"range":"31129","text":"24285"},{"range":"31130","text":"24285"},{"range":"31131","text":"24285"},{"range":"31132","text":"24285"},["31133"],{"range":"31134","text":"24285"},["31135"],["31136"],"'TSearchModel' is defined but never used.","'selectedFilterLabel' is assigned a value but never used.","'setSelectedFilterLabel' is assigned a value but never used.","'statusFilter' is assigned a value but never used.","'selectedFilters' is assigned a value but never used.","'mapStatusToFilterArray' is assigned a value but never used.","React Hook useEffect has missing dependencies: 'mapFilterToStatusArray', 'search', 'setStatusFilter', and 'statusGroups'. Either include them or remove the dependency array.",["31137"],["31138"],"'type' is defined but never used.","'viewedAt' is assigned a value but never used.",["31139"],["31140"],["31141"],["31142"],["31143"],["31144"],"Error: This value cannot be modified\n\nModifying component props or hook arguments is not allowed. Consider using a local variable instead.\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/energy-savings-applications/pdf-content/application/index.tsx:150:7\n  148 |   switch (component.type) {\n  149 |     case EComponentType.container: {\n> 150 |       dataPath = [component.key];\n      |       ^^^^^^^^ `dataPath` cannot be modified\n  151 |       const { components, columns } = component;\n  152 |       const componentFields = fields(components || columns);\n  153 |",["31145"],"'subTitle' is defined but never used.",{"range":"31146","text":"24285"},{"range":"31147","text":"24285"},{"range":"31148","text":"24285"},{"range":"31149","text":"24285"},{"range":"31150","text":"24285"},{"range":"31151","text":"24285"},{"range":"31152","text":"24285"},{"range":"31153","text":"24285"},{"range":"31154","text":"24285"},{"range":"31155","text":"24285"},{"range":"31156","text":"24285"},{"range":"31157","text":"24285"},{"range":"31158","text":"24285"},{"range":"31159","text":"24285"},{"range":"31160","text":"24285"},{"range":"31161","text":"24285"},{"range":"31162","text":"24285"},{"range":"31163","text":"24285"},{"range":"31164","text":"24285"},{"range":"31165","text":"24285"},{"range":"31166","text":"24285"},{"range":"31167","text":"24285"},{"range":"31168","text":"24285"},{"range":"31169","text":"24285"},{"range":"31170","text":"24285"},{"range":"31171","text":"24285"},{"range":"31172","text":"24285"},{"range":"31173","text":"24285"},{"range":"31174","text":"24285"},["31175"],{"range":"31176","text":"24285"},{"range":"31177","text":"24285"},{"range":"31178","text":"24285"},"'paramStatusFilter' is assigned a value but never used.",{"range":"31179","text":"24285"},{"range":"31180","text":"24285"},{"range":"31181","text":"24285"},{"range":"31182","text":"24285"},{"range":"31183","text":"24285"},{"range":"31184","text":"24285"},{"range":"31185","text":"24285"},{"range":"31186","text":"24285"},{"range":"31187","text":"24285"},{"range":"31188","text":"24285"},{"range":"31189","text":"24285"},{"range":"31190","text":"24285"},{"range":"31191","text":"24285"},{"range":"31192","text":"24285"},{"range":"31193","text":"24285"},{"range":"31194","text":"24285"},{"range":"31195","text":"24285"},{"range":"31196","text":"24285"},{"range":"31197","text":"24285"},"React Hook useEffect has missing dependencies: 'handleChange', 'paramStatusFilterString', 'selectedIndex', and 'statusStringToIndex'. Either include them or remove the dependency array.",["31198"],{"range":"31199","text":"24285"},{"range":"31200","text":"24285"},{"range":"31201","text":"24285"},{"range":"31202","text":"24285"},"'Box' is defined but never used.",["31203"],["31204"],"'Heading' is defined but never used.",["31205"],"'HStack' is defined but never used.",["31206"],["31207"],"'TextProps' is defined but never used.",["31208"],["31209"],"'jurisdiction' is assigned a value but never used.","'isDraft' is assigned a value but never used.","'applicationNumber' is assigned a value but never used.","React Hook useEffect has a missing dependency: 't'. Either include it or remove the dependency array.",["31210"],["31211"],"React Hook useEffect has a missing dependency: 'onScroll'. Either include it or remove the dependency array.",["31212"],"React Hook useEffect has missing dependencies: 'blockClasses' and 'handleBlockIntersection'. Either include them or remove the dependency array. Outer scope values like 'window.innerHeight' aren't valid dependencies because mutating them doesn't re-render the component.",["31213"],"'_event' is defined but never used.","React Hook useEffect has missing dependencies: 'handleOpenContactAutofill', 'handleOpenPreviousSubmission', and 'handleOpenStepCode'. Either include them or remove the dependency array.",["31214"],"'shouldAllowAdminEditing' is assigned a value but never used.","React Hook useMemo has missing dependencies: 'buttonsToDisable', 'currentUser?.role', 'performedBy', 'permitApplication?.latestRevisionRequests', and 'permitApplication?.status'. Either include them or remove the dependency array.",["31215"],{"range":"31216","text":"24285"},{"range":"31217","text":"24285"},{"range":"31218","text":"24285"},{"range":"31219","text":"24285"},{"range":"31220","text":"24285"},{"range":"31221","text":"24285"},{"range":"31222","text":"24285"},{"range":"31223","text":"24285"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/energy-savings-applications/scroll-link.tsx:23:5\n  21 |       }\n  22 |     }\n> 23 |     setTargetElement(element)\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  24 |   }, [to, isMounted])\n  25 |\n  26 |   const handleClick = (event: React.MouseEvent<HTMLAnchorElement, MouseEvent>) => {",{"range":"31224","text":"24285"},{"range":"31225","text":"24285"},{"range":"31226","text":"24285"},{"range":"31227","text":"24285"},{"range":"31228","text":"24285"},{"range":"31229","text":"24285"},{"range":"31230","text":"24285"},{"range":"31231","text":"24285"},{"range":"31232","text":"24285"},{"range":"31233","text":"24285"},{"range":"31234","text":"24285"},{"range":"31235","text":"24285"},{"range":"31236","text":"24285"},{"range":"31237","text":"24285"},{"range":"31238","text":"24285"},{"range":"31239","text":"24285"},{"range":"31240","text":"24285"},{"range":"31241","text":"24285"},{"range":"31242","text":"24285"},{"range":"31243","text":"24285"},{"range":"31244","text":"24285"},{"range":"31245","text":"24285"},{"range":"31246","text":"24285"},{"range":"31247","text":"24285"},{"range":"31248","text":"24285"},{"range":"31249","text":"24285"},{"range":"31250","text":"24285"},{"range":"31251","text":"24285"},{"range":"31252","text":"24285"},{"range":"31253","text":"24285"},{"range":"31254","text":"24285"},["31255"],{"range":"31256","text":"24285"},{"range":"31257","text":"24285"},{"range":"31258","text":"24285"},{"range":"31259","text":"24285"},{"range":"31260","text":"24285"},{"range":"31261","text":"24285"},{"range":"31262","text":"24285"},{"range":"31263","text":"24285"},"'handleReasonForNo' is assigned a value but never used.","'reason' is defined but never used.",{"range":"31264","text":"24285"},{"range":"31265","text":"24285"},{"range":"31266","text":"24285"},{"range":"31267","text":"24285"},{"range":"31268","text":"24285"},{"range":"31269","text":"24285"},{"range":"31270","text":"24285"},{"range":"31271","text":"24285"},{"range":"31272","text":"24285"},{"range":"31273","text":"24285"},{"range":"31274","text":"24285"},{"range":"31275","text":"24285"},{"range":"31276","text":"24285"},{"range":"31277","text":"24285"},{"range":"31278","text":"24285"},{"range":"31279","text":"24285"},{"range":"31280","text":"24285"},{"range":"31281","text":"24285"},{"range":"31282","text":"24285"},{"range":"31283","text":"24285"},{"range":"31284","text":"24285"},{"range":"31285","text":"24285"},{"range":"31286","text":"24285"},{"range":"31287","text":"24285"},{"range":"31288","text":"24285"},"'key' is assigned a value but never used.",{"range":"31289","text":"24285"},{"range":"31290","text":"24285"},{"range":"31291","text":"24285"},{"range":"31292","text":"24285"},{"range":"31293","text":"24285"},"'label' is defined but never used.",{"range":"31294","text":"24285"},{"range":"31295","text":"24285"},{"range":"31296","text":"24285"},{"range":"31297","text":"24285"},{"range":"31298","text":"24285"},{"range":"31299","text":"24285"},{"range":"31300","text":"24285"},{"range":"31301","text":"24285"},{"range":"31302","text":"24285"},["31303"],{"range":"31304","text":"24285"},{"range":"31305","text":"24285"},{"range":"31306","text":"24285"},{"range":"31307","text":"24285"},{"range":"31308","text":"24285"},{"range":"31309","text":"24285"},{"range":"31310","text":"24285"},{"range":"31311","text":"24285"},{"range":"31312","text":"24285"},{"range":"31313","text":"24285"},{"range":"31314","text":"24285"},{"range":"31315","text":"24285"},{"range":"31316","text":"24285"},{"range":"31317","text":"24285"},{"range":"31318","text":"24285"},{"range":"31319","text":"24285"},"react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/help-drawer.tsx:48:30\n  46 |   return (\n  47 |     <>\n> 48 |       {renderTriggerButton?.({ onClick: onOpen, ref: btnRef }) ?? (\n     |                              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Passing a ref to a function may read its value during render\n  49 |         <Button\n  50 |           variant=\"solid\"\n  51 |           bg=\"theme.darkBlue\"",{"range":"31320","text":"24285"},{"range":"31321","text":"24285"},{"range":"31322","text":"24285"},{"range":"31323","text":"24285"},{"range":"31324","text":"24285"},{"range":"31325","text":"24285"},{"range":"31326","text":"24285"},{"range":"31327","text":"24285"},{"range":"31328","text":"24285"},{"range":"31329","text":"24285"},{"range":"31330","text":"24285"},{"range":"31331","text":"24285"},{"range":"31332","text":"24285"},"'lastPart' is never reassigned. Use 'const' instead.",{"range":"31333","text":"31334"},{"range":"31335","text":"24285"},{"range":"31336","text":"24285"},{"range":"31337","text":"24285"},{"range":"31338","text":"24285"},{"range":"31339","text":"24285"},{"range":"31340","text":"24285"},{"range":"31341","text":"24285"},{"range":"31342","text":"24285"},{"range":"31343","text":"24285"},{"range":"31344","text":"24285"},{"range":"31345","text":"24285"},{"range":"31346","text":"24285"},{"range":"31347","text":"24285"},{"range":"31348","text":"24285"},{"range":"31349","text":"24285"},{"range":"31350","text":"24285"},{"range":"31351","text":"24285"},"'searchModel' is defined but never used.",{"range":"31352","text":"24285"},{"range":"31353","text":"24285"},{"range":"31354","text":"24285"},{"range":"31355","text":"24285"},{"range":"31356","text":"24285"},{"range":"31357","text":"24285"},{"range":"31358","text":"24285"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/add-supporting-files-pathway-modal.tsx:32:7\n  30 |   React.useEffect(() => {\n  31 |     if (isOpen) {\n> 32 |       setSelectedOption(null);\n     |       ^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  33 |     }\n  34 |   }, [isOpen]);\n  35 |",["31359"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/application-update-pathway.tsx:34:7\n  32 |   React.useEffect(() => {\n  33 |     if (isOpen) {\n> 34 |       setSelectedOption(null);\n     |       ^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  35 |     }\n  36 |   }, [isOpen]);\n  37 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/application-update-pathway.tsx:42:7\n  40 |     if (isOpen && isInternalApplication && isAdminUser) {\n  41 |       setPerformedBy(EUpdateRoles.staff);\n> 42 |       setCollectionConsentModalOpen(true);\n     |       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  43 |     }\n  44 |   }, [isOpen, isInternalApplication, isAdminUser, setPerformedBy]);\n  45 |","'confirmed' is assigned a value but never used.",["31360"],"'Flex' is defined but never used.",["31361"],"'Avatar' is defined but never used.",["31362"],"'AvatarGroup' is defined but never used.",["31363"],"'useDisclosure' is defined but never used.",["31364"],"'originalStatus' is assigned a value but never used.","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/consent-modal.tsx:28:7\n  26 |   useEffect(() => {\n  27 |     if (isOpen && permitApplication?.status !== 'revisions_requested') {\n> 28 |       setAcknowledged(false);\n     |       ^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  29 |       // Store the original status so we can restore it if user cancels\n  30 |       setOriginalStatus(permitApplication?.status);\n  31 |     }","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/eula-view-modal.tsx:44:7\n  42 |   useEffect(() => {\n  43 |     if (isOpen) {\n> 44 |       fetchEula();\n     |       ^^^^^^^^^ Avoid calling setState() directly within an effect\n  45 |     }\n  46 |   }, [isOpen, fetchEula]);\n  47 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/shared/modals/eula-view-modal.tsx:51:7\n  49 |   useEffect(() => {\n  50 |     if (!isOpen) {\n> 51 |       setError(null);\n     |       ^^^^^^^^ Avoid calling setState() directly within an effect\n  52 |       setIsLoading(false);\n  53 |     }\n  54 |   }, [isOpen]);",{"range":"31365","text":"24285"},{"range":"31366","text":"24285"},{"range":"31367","text":"24285"},{"range":"31368","text":"24285"},{"range":"31369","text":"24285"},{"range":"31370","text":"24285"},{"range":"31371","text":"24285"},{"range":"31372","text":"24285"},{"range":"31373","text":"24285"},{"range":"31374","text":"24285"},{"range":"31375","text":"24285"},{"range":"31376","text":"24285"},{"range":"31377","text":"24285"},{"range":"31378","text":"24285"},{"range":"31379","text":"24285"},{"range":"31380","text":"24285"},{"range":"31381","text":"24285"},{"range":"31382","text":"24285"},{"range":"31383","text":"24285"},{"range":"31384","text":"24285"},{"range":"31385","text":"24285"},{"range":"31386","text":"24285"},{"range":"31387","text":"24285"},{"range":"31388","text":"24285"},{"range":"31389","text":"24285"},{"range":"31390","text":"24285"},{"range":"31391","text":"24285"},{"range":"31392","text":"24285"},{"range":"31393","text":"24285"},{"range":"31394","text":"24285"},{"range":"31395","text":"24285"},{"range":"31396","text":"24285"},{"range":"31397","text":"24285"},{"range":"31398","text":"24285"},{"range":"31399","text":"24285"},{"range":"31400","text":"24285"},{"range":"31401","text":"24285"},{"range":"31402","text":"24285"},{"range":"31403","text":"24285"},{"range":"31404","text":"24285"},{"range":"31405","text":"24285"},{"range":"31406","text":"24285"},"'colors' is defined but never used.",["31407"],{"range":"31408","text":"24285"},{"range":"31409","text":"24285"},{"range":"31410","text":"24285"},{"range":"31411","text":"24285"},"'onClick' is defined but never used.",{"range":"31412","text":"24285"},{"range":"31413","text":"24285"},{"range":"31414","text":"24285"},{"range":"31415","text":"24285"},{"range":"31416","text":"24285"},{"range":"31417","text":"24285"},{"range":"31418","text":"24285"},{"range":"31419","text":"24285"},{"range":"31420","text":"24285"},{"range":"31421","text":"24285"},{"range":"31422","text":"24285"},{"range":"31423","text":"24285"},{"range":"31424","text":"24285"},{"range":"31425","text":"24285"},{"range":"31426","text":"24285"},{"range":"31427","text":"24285"},{"range":"31428","text":"28637"},{"range":"31429","text":"24285"},{"range":"31430","text":"24285"},"React Hook useEffect was passed a dependency list that is not an array literal. This means we can't statically verify whether you've passed the correct dependencies.","React Hook useEffect has a missing dependency: 'fetchOptions'. Either include it or remove the dependency array. If 'fetchOptions' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["31431"],{"range":"31432","text":"24285"},{"range":"31433","text":"24285"},{"range":"31434","text":"24285"},{"range":"31435","text":"24285"},{"range":"31436","text":"24285"},{"range":"31437","text":"24285"},{"range":"31438","text":"24285"},{"range":"31439","text":"24285"},{"range":"31440","text":"24285"},{"range":"31441","text":"24285"},{"range":"31442","text":"24285"},{"range":"31443","text":"24285"},{"range":"31444","text":"24285"},{"range":"31445","text":"24285"},{"range":"31446","text":"24285"},{"range":"31447","text":"24285"},{"range":"31448","text":"24285"},{"range":"31449","text":"24285"},{"range":"31450","text":"24285"},{"range":"31451","text":"24285"},{"range":"31452","text":"24285"},{"range":"31453","text":"24285"},{"range":"31454","text":"24285"},{"range":"31455","text":"24285"},{"range":"31456","text":"24285"},{"range":"31457","text":"26508"},{"range":"31458","text":"24285"},{"range":"31459","text":"24285"},{"range":"31460","text":"24285"},"React Hook useEffect has missing dependencies: 'fetchOptions' and 'onChange'. Either include them or remove the dependency array. If 'fetchOptions' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["31461"],{"range":"31462","text":"24285"},{"range":"31463","text":"24285"},{"range":"31464","text":"24285"},{"range":"31465","text":"24285"},{"range":"31466","text":"24285"},{"range":"31467","text":"24285"},{"range":"31468","text":"24285"},{"range":"31469","text":"24285"},{"range":"31470","text":"24285"},{"range":"31471","text":"24285"},{"range":"31472","text":"24285"},{"range":"31473","text":"24285"},{"range":"31474","text":"24285"},{"range":"31475","text":"24285"},["31476"],{"range":"31477","text":"24285"},{"range":"31478","text":"24285"},{"range":"31479","text":"24285"},{"range":"31480","text":"24285"},{"range":"31481","text":"24285"},{"range":"31482","text":"24285"},{"range":"31483","text":"24285"},{"range":"31484","text":"24285"},{"range":"31485","text":"24285"},{"range":"31486","text":"24285"},{"range":"31487","text":"24285"},{"range":"31488","text":"24285"},{"range":"31489","text":"24285"},{"range":"31490","text":"24285"},{"range":"31491","text":"24285"},{"range":"31492","text":"24285"},{"range":"31493","text":"24285"},{"range":"31494","text":"24285"},{"range":"31495","text":"24285"},{"range":"31496","text":"24285"},{"range":"31497","text":"24285"},{"range":"31498","text":"24285"},{"range":"31499","text":"24285"},{"range":"31500","text":"24285"},{"range":"31501","text":"24285"},"'setCopyExisting' is assigned a value but never used.","React Hook useEffect has a missing dependency: 'permitClassificationStore'. Either include it or remove the dependency array.",["31502"],"'YesNoTag' is defined but never used.",["31503"],{"range":"31504","text":"24285"},{"range":"31505","text":"24285"},{"range":"31506","text":"24285"},{"range":"31507","text":"24285"},{"range":"31508","text":"24285"},{"range":"31509","text":"24285"},{"range":"31510","text":"24285"},{"range":"31511","text":"24285"},{"range":"31512","text":"24285"},{"range":"31513","text":"24285"},{"range":"31514","text":"24285"},{"range":"31515","text":"24285"},{"range":"31516","text":"24285"},{"range":"31517","text":"24285"},{"range":"31518","text":"24285"},{"range":"31519","text":"24285"},{"range":"31520","text":"24285"},{"range":"31521","text":"24285"},{"range":"31522","text":"24285"},{"range":"31523","text":"24285"},{"range":"31524","text":"24285"},{"range":"31525","text":"24285"},{"range":"31526","text":"24285"},{"range":"31527","text":"24285"},{"range":"31528","text":"24285"},{"range":"31529","text":"24285"},{"range":"31530","text":"24285"},{"range":"31531","text":"24285"},{"range":"31532","text":"24285"},"'Spacer' is defined but never used.",["31533"],"'Trash' is defined but never used.",["31534"],"'SingleRequirementForm' is defined but never used.",["31535"],"'requirementForm' is assigned a value but never used.",{"range":"31536","text":"24285"},{"range":"31537","text":"24285"},{"range":"31538","text":"24285"},{"range":"31539","text":"24285"},{"range":"31540","text":"24285"},{"range":"31541","text":"24285"},{"range":"31542","text":"24285"},{"range":"31543","text":"24285"},{"range":"31544","text":"24285"},{"range":"31545","text":"24285"},{"range":"31546","text":"24285"},{"range":"31547","text":"24285"},{"range":"31548","text":"24285"},{"range":"31549","text":"24285"},{"range":"31550","text":"24285"},{"range":"31551","text":"24285"},{"range":"31552","text":"24285"},{"range":"31553","text":"24285"},{"range":"31554","text":"24285"},{"range":"31555","text":"24285"},{"range":"31556","text":"24285"},{"range":"31557","text":"24285"},{"range":"31558","text":"24285"},{"range":"31559","text":"24285"},{"range":"31560","text":"24285"},{"range":"31561","text":"24285"},{"range":"31562","text":"24285"},{"range":"31563","text":"24285"},{"range":"31564","text":"24285"},{"range":"31565","text":"24285"},{"range":"31566","text":"24285"},{"range":"31567","text":"24285"},{"range":"31568","text":"24285"},{"range":"31569","text":"24285"},{"range":"31570","text":"24285"},"'css' is defined but never used.",{"range":"31571","text":"24285"},{"range":"31572","text":"24285"},{"range":"31573","text":"24285"},{"range":"31574","text":"24285"},{"range":"31575","