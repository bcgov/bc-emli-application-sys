rn/you-might-not-need-an-effect).\n\n/home/siegleda/workspace/bc-emli-application-sys/app/frontend/components/domains/requirement-template/screens/base-edit-requirement-template-screen/sections-dnd/index.tsx:79:5\n  77 |   useEffect(() => {\n  78 |     const newDndSectionMap = formSectionsMapFromSections(sections)\n> 79 |     setDndSectionMap(newDndSectionMap)\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  80 |     setSortedSectionIds(Object.keys(newDndSectionMap))\n  81 |   }, [sections])\n  82 |",{"range":"26100","text":"24285"},{"range":"26101","text":"24285"},{"range":"26102","text":"24285"},{"range":"26103","text":"24285"},{"range":"26104","text":"24285"},{"range":"26105","text":"24285"},{"range":"26106","text":"24285"},{"range":"26107","text":"24285"},{"range":"26108","text":"24285"},{"range":"26109","text":"24285"},{"range":"26110","text":"24285"},{"range":"26111","text":"24285"},{"range":"26112","text":"24285"},"React Hook useCallback has missing dependencies: 'getSectionById' and 'isSection'. Either include them or remove the dependency array.",["26113"],{"range":"26114","text":"24285"},{"range":"26115","text":"24285"},{"range":"26116","text":"24285"},{"range":"26117","text":"24285"},{"range":"26118","text":"24285"},{"range":"26119","text":"24285"},{"range":"26120","text":"24285"},{"range":"26121","text":"24285"},"'index' is defined but never used.",{"range":"26122","text":"24285"},{"range":"26123","text":"24285"},{"range":"26124","text":"24285"},{"range":"26125","text":"24285"},{"range":"26126","text":"24285"},{"range":"26127","text":"24285"},{"range":"26128","text":"24285"},{"range":"26129","text":"24285"},{"range":"26130","text":"24285"},{"range":"26131","text":"24285"},{"range":"26132","text":"24285"},{"range":"26133","text":"24285"},{"range":"26134","text":"24285"},{"range":"26135","text":"24285"},{"range":"26136","text":"24285"},{"range":"26137","text":"24285"},{"range":"26138","text":"24285"},{"range":"26139","text